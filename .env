# FIXME: Configure environment variables for your project

# Need advanced features? Next.js 16 & React 19, Multi-tenancy & Teams, Roles & Permissions, Shadcn UI, End-to-End Typesafety with oRPC,
# Stripe Payment, Light / Dark mode. Try Next.js Boilerplate Pro: https://nextjs-boilerplate.com/pro-saas-starter-kit

# Or, need a Self-hosted auth stack (Better Auth)? Try Next.js Boilerplate Max: https://nextjs-boilerplate.com/nextjs-multi-tenant-saas-boilerplate

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_b3Blbi1zdGlua2J1Zy04LmNsZXJrLmFjY291bnRzLmRldiQ

# Database
# Local database with PGLite, already included in the project, no Docker needed
# Need a database for production? Check out https://get.neon.com/BMFYNtx
# Tested and compatible with SaaS Boilerplate
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres

# Next.js
NEXT_TELEMETRY_DISABLED=1

# Logging
NEXT_PUBLIC_LOGGING_LEVEL=debug

# Payments — public/non-secret values only. Put secret keys in .env.local (git-ignored).
# Currency applies to both gateways (single-currency starter; see AGENTS.md).
PAYMENTS_CURRENCY=USD
# Razorpay publishable key id (safe to expose to the browser)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Product analytics — PostHog (optional). Safe to expose to the browser; leave both blank to disable.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

######## [BEGIN] SENSITIVE DATA ######## For security reason, don't update the following variables (secret key) directly in this file.
######## Please create a new file named `.env.local`, all environment files ending with `.local` won't be tracked by Git.
######## After creating the file, you can add the following variables.
# Clerk authentication
CLERK_SECRET_KEY=your_clerk_secret_key
# Clerk webhooks (optional) — set when you register the /api/webhooks/clerk endpoint in the Clerk dashboard
CLERK_WEBHOOK_SECRET=

# Transactional email — Resend (optional). sendEmail() no-ops without RESEND_API_KEY.
# Put a verified-domain sender in EMAIL_FROM for production (defaults to onboarding@resend.dev in dev).
RESEND_API_KEY=
EMAIL_FROM=

# Rate limiting — Upstash Redis (optional, defense-in-depth). limit() allows every request through when unconfigured.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe (create prices in the Stripe dashboard, paste their price_... ids)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_ENTERPRISE=

# Razorpay (create plans in the Razorpay dashboard, paste their plan_... ids)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PREMIUM=
RAZORPAY_PLAN_ENTERPRISE=

# Object storage — S3-compatible (Cloudflare R2, AWS S3). Optional: the app boots
# without it, but uploads fail loudly rather than silently doing nothing.
# R2 is the lazy default (same API, no egress fees):
#   STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   STORAGE_REGION=auto
# For AWS S3, leave STORAGE_ENDPOINT unset and set a real region (e.g. us-east-1).
# STORAGE_PUBLIC_URL is the base objects are served from (r2.dev, a custom domain,
# or a CDN) — the bucket's own S3 endpoint is not publicly readable.
STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=
######## [END] SENSITIVE DATA
